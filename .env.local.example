# Supabase Configuration
# Nuvem: https://app.supabase.com → Your Project → Settings → API
# Local: após `supabase start`, use `supabase status` (URL http://127.0.0.1:54321)

# ✅ Required (use anon OU publishable — não precisa das duas)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Alternativa ao nome anon (dashboard Supabase novo):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# ⏺️ Optional (for admin operations only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
