# ============================================
# SECRM - .gitignore
# ============================================

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Testing ---
/coverage

# --- Next.js ---
/.next/
/out/

# --- Production build ---
/build

# --- Environment variables ---
.env
.env.local
.env.*.local
!.env.local.example

# --- OS / Editor ---
.DS_Store
Thumbs.db
*.pem
.vscode/settings.json
.idea/

# --- Debug logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Python venv ---
.venv/
__pycache__/

# --- Deploy platforms ---
.vercel
.netlify

# --- TypeScript ---
*.tsbuildinfo
next-env.d.ts
